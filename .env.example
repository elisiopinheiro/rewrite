# Clusters-4wm v3 — Environment Variables
# Copy this file to .env and adjust values for your environment.

# Application
APP_VERSION=development
APP_ENVIRONMENT=dev

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clusters
DB_USERNAME=cluster_app
DB_PASSWORD=password

# Authentication — M4W API
BASIC_API_USERNAME=4wm
BASIC_API_PASSWORD=4wm

# Authentication — Partner API
BASIC_M4W_API_USERNAME=ctw
BASIC_M4W_API_PASSWORD=ctw
BASIC_CLOUD_API_USERNAME=cloud
BASIC_CLOUD_API_PASSWORD=cloud
BASIC_SCP_API_USERNAME=scp
BASIC_SCP_API_PASSWORD=scp
BASIC_SOLAR_API_USERNAME=solar
BASIC_SOLAR_API_PASSWORD=solar

# Validation
ADGR_GROUP_REGEX=^(APPL_|RN-|RN_).*$

# Logging
DATABASE_LOGGING_LEVEL=WARN
